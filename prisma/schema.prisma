generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Utilisateur {
  id                    String        @id @default(cuid())
  email                 String        @unique
  motDePasse            String
  nom                   String
  prenom                String?
  telephone             String?
  emailVerifie          Boolean       @default(false)
  role                  Role          @default(COMMERCANT)
  tokenVerification     String?       @unique
  tokenReinitialisation String?
  dateExpirationToken   DateTime?
  dateCreation          DateTime      @default(now())
  dateMiseAJour         DateTime      @updatedAt
  abonnements           Abonnement[]
  boutiques             Boutique[]
  boutiqueGeree         Boutique?     @relation("Gerant")
  transactions          Transaction[] @relation("TransactionsVerifiees")
  ventes                Vente[]
}

model Boutique {
  id            String        @id @default(cuid())
  nom           String
  commercantId  String
  gerantId      String?       @unique
  solde         Float         @default(0)
  dateCreation  DateTime      @default(now())
  dateMiseAJour DateTime      @updatedAt
  abonnements   Abonnement[]
  commercant    Utilisateur   @relation(fields: [commercantId], references: [id])
  gerant        Utilisateur?  @relation("Gerant", fields: [gerantId], references: [id])
  employes      Employe[]
  transactions  Transaction[]
  ventes        Vente[]
}

model Employe {
  id            String    @id @default(cuid())
  nom           String
  prenom        String?
  telephone     String
  code          String    @unique
  utilisateurId String?   @unique // Lien vers un compte utilisateur
  boutiqueId    String?
  dateCreation  DateTime  @default(now())
  dateMiseAJour DateTime  @updatedAt
  boutique      Boutique? @relation(fields: [boutiqueId], references: [id])
}

model Vente {
  id              String      @id @default(cuid())
  montant         Float
  description     String?
  boutiqueId      String
  enregistreParId String
  dateVente       DateTime    @default(now())
  dateCreation    DateTime    @default(now())
  boutique        Boutique    @relation(fields: [boutiqueId], references: [id])
  enregistrePar   Utilisateur @relation(fields: [enregistreParId], references: [id])
}

model Transaction {
  id              String          @id @default(cuid())
  type            TypeTransaction
  montant         Float
  description     String?
  reference       String?
  boutiqueId      String
  verifiee        Boolean         @default(false)
  verifieeParId   String?
  dateTransaction DateTime        @default(now())
  dateCreation    DateTime        @default(now())
  boutique        Boutique        @relation(fields: [boutiqueId], references: [id])
  verifieePar     Utilisateur?    @relation("TransactionsVerifiees", fields: [verifieeParId], references: [id])
}

model Abonnement {
  id           String           @id @default(cuid())
  boutiqueId   String
  commercantId String
  duree        DureeAbonnement
  statut       StatutAbonnement @default(ACTIF)
  dateDebut    DateTime         @default(now())
  dateFin      DateTime
  montant      Float
  dateCreation DateTime         @default(now())
  boutique     Boutique         @relation(fields: [boutiqueId], references: [id])
  commercant   Utilisateur      @relation(fields: [commercantId], references: [id])
}

enum Role {
  ADMIN
  COMMERCANT
  EMPLOYE
}

enum DureeAbonnement {
  ESSAI_7J
  UN_MOIS
  TROIS_MOIS
  SIX_MOIS
  UN_AN
}

enum StatutAbonnement {
  ACTIF
  EXPIRE
  ANNULE
}

enum TypeTransaction {
  VENTE
  VERSEMENT
  DEPENSE
  VIREMENT_BANCAIRE
  RETRAIT
}
